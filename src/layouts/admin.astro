---
import "@/styles/global.css"
import { Sidebar } from "@/components/Sidebar"
import { ViewTransitions } from "astro:transitions"

interface Props {
  title?: string
}

const { title = "Delta FM" } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Delta FM</title>
    <!-- Runs synchronously before first paint to prevent theme flash -->
    <script is:inline>
      const theme = localStorage.getItem("fm-theme");
      if (theme !== "light") {
        document.documentElement.classList.add("dark");
      }
    </script>
    <ViewTransitions />
  </head>
  <body class="flex h-svh overflow-hidden bg-background text-foreground">
    <Sidebar client:only="react" transition:persist />
    <main class="flex flex-1 flex-col overflow-y-auto">
      <slot />
    </main>
  </body>
</html>
