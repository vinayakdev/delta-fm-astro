---
import "@/styles/global.css"
import { Sidebar } from "@/components/Sidebar"
import { ViewTransitions } from "astro:transitions"

interface Props {
  title?: string
}

const { title = "Delta FM" } = Astro.props

// Read persisted preferences from cookies so the server renders
// the sidebar with correct initial values — no hydration mismatch.
const isDark = Astro.cookies.get("fm-theme")?.value !== "light"
const currency = Astro.cookies.get("fm-currency")?.value === "INR" ? "INR" : "USD"
---

<html lang="en" class={isDark ? "dark" : ""}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Delta FM</title>
    <ViewTransitions />
  </head>
  <body class="flex h-svh overflow-hidden bg-background text-foreground">
    <Sidebar initialDark={isDark} initialCurrency={currency} client:load transition:persist />
    <main class="flex flex-1 flex-col overflow-y-auto">
      <slot />
    </main>
  </body>
</html>
